# LinkedIn Sales MCP — Environment Variables

# Gemini API key for AI intent classification
GEMINI_API_KEY=AIzaSy...

# OAuth secret (random, for signing)
OAUTH_SECRET=change-me-to-random-64-chars

# PIN that Mike enters to approve OAuth access (required!)
OAUTH_APPROVE_SECRET=your-pin-here

# Optional: pre-register OAuth client for claude.ai
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=

# Public URL (must match DNS + Traefik)
PUBLIC_URL=https://mcp-linkedin.bartoszgaca.pl
